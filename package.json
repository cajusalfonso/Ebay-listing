{
  "name": "ebay-volume-tool",
  "version": "0.1.0",
  "private": true,
  "description": "eBay.de automatisiertes Volumen-Listing mit Compliance-First (Phase 1 MVP)",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cli": "tsx src/cli/index.ts",
    "api": "tsx src/api/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "setup": "tsx src/cli/setup.ts",
    "setup:ebay-auth": "tsx src/cli/setup-ebay-auth.ts",
    "setup:resolve-categories": "tsx src/cli/setup-resolve-categories.ts",
    "cli:enrich": "tsx src/cli/enrich.ts",
    "cli:market": "tsx src/cli/market.ts",
    "cli:price": "tsx src/cli/price.ts",
    "cli:list-product": "tsx src/cli/list-product.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.7.4",
    "bcryptjs": "2.4.3",
    "citty": "0.1.6",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "16.4.7",
    "drizzle-orm": "0.38.3",
    "fast-xml-parser": "4.5.1",
    "fastify": "5.2.1",
    "lucide-react": "0.469.0",
    "next": "15.1.4",
    "next-auth": "5.0.0-beta.25",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "postgres": "3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5",
    "tailwind-merge": "2.6.0",
    "undici": "7.2.3",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.5",
    "@types/react": "19.0.5",
    "@types/react-dom": "19.0.3",
    "@vitest/coverage-v8": "2.1.8",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.30.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.1.4",
    "eslint-config-prettier": "9.1.0",
    "postcss": "8.4.49",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.19.0",
    "vitest": "2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  }
}
