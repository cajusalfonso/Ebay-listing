# ---------- App ----------
NODE_ENV=development
LOG_LEVEL=debug

# ---------- Database ----------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ebay_tool

# ---------- eBay API ----------
# sandbox | production — Production-Publish erfordert zusätzlich --env=production --yes-really CLI-Flag
EBAY_ENV=sandbox
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=
# RuName aus eBay Dev Dashboard (Auth'n'Auth → User Tokens → RuName)
EBAY_REDIRECT_URI_NAME=

# ---------- Icecat Open Catalog ----------
ICECAT_USER=
ICECAT_PASSWORD=

# ---------- Discord ----------
DISCORD_WEBHOOK_URL=

# ---------- Pricing Rules ----------
MIN_ABSOLUTE_PROFIT_EUR=10
MIN_MARGIN_PERCENT=0.08
DEFAULT_VAT_RATE=0.19
DEFAULT_EBAY_FEE_PERCENT=0.12
DEFAULT_EBAY_FIXED_FEE_EUR=0.35
DEFAULT_RETURN_RESERVE_PERCENT=0.03
UNDERCUT_AMOUNT_EUR=0.50
TARGET_MARGIN_MULTIPLIER=1.25

# ---------- Storage ----------
IMAGE_STORAGE_PATH=./storage/images

# ---------- Security ----------
# 32-byte hex — generate via: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=
